# Listing copy (safe defaults exist if unset)
DEMO_LISTING_TITLE=ReRoute demo — delete me
DEMO_LISTING_PRICE=29.99
DEMO_LISTING_DESCRIPTION=Demo listing generated by ReRoute automation.

# Absolute path to one listing image on disk (optional)
# DEMO_IMAGE_PATH=/Users/you/Pictures/demo-item.jpg

# Optional: override start URLs after you copy the exact seller URL from your browser
# EBAY_SELL_START_URL=https://www.ebay.com/sl/sell
# FB_MARKETPLACE_CREATE_URL=https://www.facebook.com/marketplace/create/item

# Milliseconds to leave the browser open before the test ends (for recording / manual publish)
DEMO_PAUSE_MS=8000

# Set to 1 for headless CI (demo usually wants visible browser)
# HEADLESS=0
