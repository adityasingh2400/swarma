# ReRoute Environment Configuration

# Gemini — up to 10 keys across GCP projects for concurrent round-robin
GEMINI_API_KEY=your_gemini_api_key
# GEMINI_API_KEY_2=your_second_key
# GEMINI_API_KEY_3=your_third_key
# GEMINI_API_KEY_4=
# GEMINI_API_KEY_5=
# GEMINI_API_KEY_6=
# GEMINI_API_KEY_7=
# GEMINI_API_KEY_8=
# GEMINI_API_KEY_9=
# GEMINI_API_KEY_10=

# ASI:One (Fetch.ai LLM)
ASI_ONE_API_KEY=your_asi_one_api_key

# eBay
EBAY_APP_ID=your_ebay_app_id
EBAY_CERT_ID=your_ebay_cert_id
EBAY_DEV_ID=your_ebay_dev_id
EBAY_OAUTH_TOKEN=your_ebay_oauth_token
EBAY_SANDBOX=true

# Amazon Product Advertising API
AMAZON_ACCESS_KEY=your_amazon_access_key
AMAZON_SECRET_KEY=your_amazon_secret_key
AMAZON_PARTNER_TAG=your_amazon_partner_tag

# Agent Seeds (unique phrases for each agent)
INTAKE_AGENT_SEED=reroute-intake-agent-seed-phrase-change-me
CONDITION_FUSION_AGENT_SEED=reroute-condition-fusion-seed-phrase-change-me
RETURN_AGENT_SEED=reroute-return-agent-seed-phrase-change-me
TRADE_IN_AGENT_SEED=reroute-trade-in-agent-seed-phrase-change-me
MARKETPLACE_RESALE_AGENT_SEED=reroute-marketplace-resale-seed-phrase-change-me
REPAIR_ROI_AGENT_SEED=reroute-repair-roi-agent-seed-phrase-change-me
BUNDLE_OPPORTUNITY_AGENT_SEED=reroute-bundle-opportunity-seed-phrase-change-me
ROUTE_DECIDER_AGENT_SEED=reroute-route-decider-agent-seed-phrase-change-me
CONCIERGE_AGENT_SEED=reroute-concierge-agent-seed-phrase-change-me

# Server
API_HOST=0.0.0.0
API_PORT=8080
BUREAU_PORT=8000
UPLOAD_DIR=./data/uploads
FRAMES_DIR=./data/frames
OPTIMIZED_DIR=./data/optimized
JOBS_DIR=./data/jobs

# Feature Flags
ENABLE_FACEBOOK_ADAPTER=false
ENABLE_DEPOP_ADAPTER=false
DEMO_MODE=true
