# Browser-Use Cloud
BROWSER_USE_API_KEY=your_browser_use_api_key
USE_CLOUD=true
USE_CHAT_BROWSER_USE=false
MAX_CONCURRENT_AGENTS=15

# Gemini — round-robin keys (as many as you have)
GEMINI_API_KEY=your_gemini_key_1
GEMINI_API_KEY_2=your_gemini_key_2
GEMINI_API_KEY_3=your_gemini_key_3
GEMINI_API_KEY_4=
GEMINI_API_KEY_5=
GEMINI_API_KEY_6=
GEMINI_API_KEY_7=
GEMINI_API_KEY_8=
GEMINI_API_KEY_9=
GEMINI_API_KEY_10=

# Auth cookies (export from browser, Playwright JSON format)
FACEBOOK_COOKIES=./auth/facebook-cookies.json
DEPOP_COOKIES=./auth/depop-cookies.json

# Server
API_HOST=0.0.0.0
API_PORT=8080
